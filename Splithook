// ══════════════════════════════════════════════════
const CAT_META = {
  w: {label:'🏆 Winning',color:'var(--good)',  bg:'rgba(62,207,142,.12)'},
  m: {label:'💰 Мөнгө',  color:'#ff6b35',      bg:'rgba(255,107,53,.12)'},
  s: {label:'🔥 Зун',    color:'var(--acc)',    bg:'rgba(200,255,0,.1)'},
  f: {label:'😱 FOMO',   color:'var(--ugc)',    bg:'rgba(255,185,48,.12)'},
  p: {label:'😤 Pain',   color:'var(--acc2)',   bg:'rgba(0,229,255,.1)'},
  c: {label:'🤫 Нууц',   color:'#e879f9',       bg:'rgba(232,121,249,.1)'},
};

let currentCat = 'all';
let copiedCount = 0;

function buildCard(h){
  const cm = CAT_META[h.cat];
  return `<div class="scard" data-cat="${h.cat}" data-search="${(h.hook+' '+h.visual).toLowerCase()}">
    <div class="scard-bar" style="background:${cm.color}"></div>
    <div class="scard-hd">
      <span class="scard-num">#${String(h.id).padStart(3,'0')}</span>
      <div class="scard-badges">
        <span class="badge" style="background:${cm.bg};color:${cm.color}">${cm.label}</span>
      </div>
    </div>
    <div class="split-wrap">
      <div class="split-top">
        <span class="split-top-label">ДЭЭД · БАРАА</span>
        <span class="split-top-icon">🎬</span>
        <div class="split-top-txt">${h.visual}</div>
      </div>
      <div class="split-line"></div>
      <div class="split-bot">
        <span class="split-bot-label">ДООД · ЧИ</span>
        <span class="split-mic">🎙</span>
        <div class="split-hook">${h.hook}</div>
      </div>
    </div>
    <div class="scard-ft">
      <div class="tip-txt">💡 ${h.tip}</div>
      <button class="cpybtn" onclick="copyHook(this,\`${h.hook.replace(/`/g,'\\`')}\`)">Copy</button>
    </div>
  </div>`;
}

function renderGrid(cat, query=''){
  const grid = document.getElementById('main-grid');
  let list = cat==='all' ? HOOKS : HOOKS.filter(h=>h.cat===cat);
  if(query) list = list.filter(h=>(h.hook+h.visual).toLowerCase().includes(query.toLowerCase()));
  document.getElementById('vis-cnt').textContent = list.length;
  if(!list.length){
    grid.innerHTML = `<div class="empty"><div class="empty-ic">🔍</div><div class="empty-tx">"${query}" — илэрц олдсонгүй</div></div>`;
    document.getElementById('res-count').textContent = '0 hook';
    return;
  }
  grid.innerHTML = list.map(buildCard).join('');
  document.getElementById('res-count').textContent = query ? list.length+' үр дүн' : '';
}

function sw(cat, btn){
  currentCat = cat;
  document.querySelectorAll('.ntab').forEach(t=>t.classList.remove('on'));
  if(btn){btn.classList.add('on')}
  document.getElementById('search-in').value='';
  document.getElementById('res-count').textContent='';
  renderGrid(cat);
}

function doSearch(q){ renderGrid(currentCat, q); }

// Copy with fallback for mobile
function doCopy(text, onOk){
  if(navigator.clipboard && window.isSecureContext){
    navigator.clipboard.writeText(text).then(onOk).catch(()=>fallback(text,onOk));
  } else { fallback(text,onOk); }
}
function fallback(text,onOk){
  const ta=document.createElement('textarea');
  ta.value=text;
  ta.style.cssText='position:fixed;left:-9999px;top:-9999px;opacity:0;font-size:16px';
  document.body.appendChild(ta);
  ta.focus();ta.select();
  try{document.execCommand('copy');onOk();}catch(e){}
  document.body.removeChild(ta);
}

function copyHook(btn,text){
  doCopy(text,()=>{
    btn.textContent='✓ OK';btn.classList.add('ok');
    copiedCount++;
    document.getElementById('copied-cnt').textContent=copiedCount;
    showToast('✓ Hook copied!');
    setTimeout(()=>{btn.textContent='Copy';btn.classList.remove('ok');},2000);
  });
}

function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2200);
}

function rollRandom(){
  const pool=currentCat==='all'?HOOKS:HOOKS.filter(h=>h.cat===currentCat);
  const h=pool[Math.floor(Math.random()*pool.length)];
  const cm=CAT_META[h.cat];
  document.getElementById('rand-visual').innerHTML=`<strong style="color:var(--acc);font-size:9px;font-family:var(--mo);letter-spacing:.1em;display:block;margin-bottom:4px">🎬 БАРАА:</strong>${h.visual}`;
  document.getElementById('rand-hook').textContent=h.hook;
  document.getElementById('rand-meta').textContent=`#${h.id} · ${cm.label} · 💡 ${h.tip}`;
  document.getElementById('rand-wrap').dataset.hook=h.hook;
}

function copyRand(){
  const hook=document.getElementById('rand-hook').textContent;
  if(hook&&hook!=='Уншиж байна...'){
    doCopy(hook,()=>{
      copiedCount++;
      document.getElementById('copied-cnt').textContent=copiedCount;
      showToast('✓ Copied!');
    });
  }
}

// Nav counts
function initCounts(){
  const cats=['w','m','s','f','p','c'];
  cats.forEach(c=>{
    const el=document.getElementById('nc-'+c);
    if(el) el.textContent=HOOKS.filter(h=>h.cat===c).length;
  });
  document.getElementById('nc-all').textContent=HOOKS.length;
}

initCounts();
renderGrid('all');
rollRandom();
</script>
