    <button class="ntab ts" id="tab-s" onclick="sw('s',this)">🔥 Зун<span class="nc" id="nc-s"></span></button>
    <button class="ntab tf" id="tab-f" onclick="sw('f',this)">😱 FOMO<span class="nc" id="nc-f"></span></button>
    <button class="ntab tp" id="tab-p" onclick="sw('p',this)">😤 Pain<span class="nc" id="nc-p"></span></button>
    <button class="ntab tc" id="tab-c" onclick="sw('c',this)">🤫 Нууц<span class="nc" id="nc-c"></span></button>
    <div class="nav-sep"></div>
    <button class="rand-nav" onclick="rollRandom()">🎲 Random</button>
  </div>
</nav>

<div class="content">

  <!-- RANDOM -->
  <div class="rand-wrap" id="rand-wrap">
    <div class="rand-lbl">🎲 Өнөөдрийн hook</div>
    <div class="rand-split">
      <div class="rand-top" id="rand-visual">...</div>
      <div class="rand-bot">
        <div class="rand-hook-txt" id="rand-hook">Уншиж байна...</div>
      </div>
    </div>
    <div class="rand-meta" id="rand-meta"></div>
    <div class="rand-acts">
      <button class="rbtn primary" onclick="copyRand()">Hook copy хийх</button>
      <button class="rbtn sec" onclick="rollRandom()">🎲 Өөр</button>
    </div>
  </div>

  <!-- SEARCH -->
  <div class="toolbar">
    <div class="sw"><span class="si">⌕</span><input class="sin" id="search-in" placeholder="Hook хайх..." oninput="doSearch(this.value)" autocomplete="off"></div>
    <span class="rc" id="res-count"></span>
  </div>

  <div class="grid" id="main-grid"></div>
</div>

<div class="toast" id="toast"></div>

