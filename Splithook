<!DOCTYPE html>
<html lang="mn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Split-Screen Hook Bank — 200 Hooks</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07070a;--s1:#0e0e12;--s2:#141418;--s3:#1a1a20;
  --bd:#1f1f28;--bd2:#2c2c38;--tx:#e2e2f0;--mt:#52526a;--mt2:#8888a0;--wh:#f5f5ff;
  --acc:#c8ff00;--acc2:#00e5ff;--warn:#ff6b35;--good:#3ecf8e;
  --ugc:#ffb930;--vo:#7c6fff;
  --fn:'Inter',sans-serif;--mo:'JetBrains Mono',monospace;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--tx);font-family:var(--fn);font-size:15px;line-height:1.65;-webkit-font-smoothing:antialiased;min-height:100vh}

/* HERO */
.hero{padding:48px 24px 36px;max-width:960px;margin:0 auto;position:relative}
.hero::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--acc),transparent);opacity:.4}
.hero-ey{font-family:var(--mo);font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:var(--mt2);margin-bottom:14px;display:flex;align-items:center;gap:10px}
.hero-ey::before{content:'';width:20px;height:1px;background:var(--mt2)}
.hero-title{font-size:clamp(36px,7vw,72px);font-weight:900;letter-spacing:-.05em;line-height:.95;color:var(--wh)}
.hero-title em{font-style:normal;color:var(--acc)}
.hero-sub{font-size:14px;color:var(--mt2);max-width:480px;line-height:1.8;margin-top:12px}
.hero-stats{display:flex;gap:28px;margin-top:24px;flex-wrap:wrap}
.hs{display:flex;flex-direction:column;gap:2px}
.hs-val{font-family:var(--mo);font-size:20px;font-weight:700;color:var(--acc)}
.hs-lbl{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--mt)}

/* HOW-TO BANNER */
.how-banner{max-width:960px;margin:0 auto 0;padding:0 24px}
.how-inner{background:var(--s1);border:1px solid var(--bd);border-top:2px solid var(--acc);padding:16px 20px;display:flex;gap:24px;flex-wrap:wrap;align-items:flex-start}
.how-item{display:flex;gap:10px;align-items:flex-start;flex:1;min-width:180px}
.how-num{font-family:var(--mo);font-size:10px;font-weight:700;color:var(--acc);background:rgba(200,255,0,.1);border:1px solid rgba(200,255,0,.2);padding:2px 7px;flex-shrink:0;margin-top:2px}
.how-txt{font-size:12px;color:var(--mt2);line-height:1.6}
.how-txt strong{color:var(--tx)}

/* NAV */
.nav{position:sticky;top:0;z-index:200;background:rgba(7,7,10,.96);backdrop-filter:blur(24px);border-bottom:1px solid var(--bd);margin-top:20px}
.nav-inner{max-width:960px;margin:0 auto;display:flex;align-items:center;gap:2px;padding:0 24px;overflow-x:auto;scrollbar-width:none}
.nav-inner::-webkit-scrollbar{display:none}
.ntab{padding:14px 14px;font-family:var(--fn);font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--mt2);cursor:pointer;border:none;background:none;border-bottom:2px solid transparent;white-space:nowrap;transition:all .15s;-webkit-tap-highlight-color:transparent}
.ntab:hover{color:var(--tx)}
.ntab.on{color:var(--acc);border-bottom-color:var(--acc)}
.ntab.on.tw{color:var(--good);border-bottom-color:var(--good)}
.ntab.on.tm{color:#ff6b35;border-bottom-color:#ff6b35}
.ntab.on.ts{color:var(--acc2);border-bottom-color:var(--acc2)}
.ntab.on.tf{color:var(--ugc);border-bottom-color:var(--ugc)}
.ntab.on.tp{color:var(--vo);border-bottom-color:var(--vo)}
.ntab.on.tc{color:#e879f9;border-bottom-color:#e879f9}
.nav-sep{width:1px;height:22px;background:var(--bd2);margin:0 4px;flex-shrink:0}
.nc{font-family:var(--mo);font-size:9px;margin-left:4px;opacity:.55}
.rand-nav{padding:7px 12px;font-family:var(--mo);font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;background:rgba(200,255,0,.08);border:1px solid rgba(200,255,0,.2);color:var(--acc);transition:all .15s;white-space:nowrap;-webkit-tap-highlight-color:transparent}
.rand-nav:hover{background:rgba(200,255,0,.15)}

/* CONTENT */
.content{max-width:960px;margin:0 auto;padding:24px 24px 100px}

/* TOOLBAR */
.toolbar{display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;align-items:center}
.sw{flex:1;min-width:200px;position:relative}
.si{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--mt);font-size:13px;pointer-events:none}
.sin{width:100%;background:var(--s1);border:1px solid var(--bd);padding:11px 14px 11px 34px;font-family:var(--fn);font-size:14px;color:var(--tx);outline:none;transition:border-color .15s;-webkit-appearance:none}
.sin:focus{border-color:var(--bd2)}.sin::placeholder{color:var(--mt)}
.rc{font-family:var(--mo);font-size:11px;color:var(--mt);white-space:nowrap;align-self:center}

/* GRID */
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px}

/* ── SPLIT CARD ── */
.scard{background:var(--s1);border:1px solid var(--bd);overflow:hidden;transition:border-color .2s;display:flex;flex-direction:column}
.scard:hover{border-color:var(--bd2)}

/* CARD TOP BAR */
.scard-bar{height:2px;width:100%}

/* CARD HEADER */
.scard-hd{display:flex;align-items:center;justify-content:space-between;padding:9px 12px 8px;border-bottom:1px solid var(--bd)}
.scard-num{font-family:var(--mo);font-size:9px;color:var(--mt);letter-spacing:.08em}
.scard-badges{display:flex;gap:4px;align-items:center}
.badge{font-family:var(--mo);font-size:8px;letter-spacing:.1em;text-transform:uppercase;padding:2px 7px;font-weight:700}

/* SPLIT VISUAL — the reel mockup */
.split-wrap{display:flex;flex-direction:column}

/* TOP HALF — 바라a visual note */
.split-top{background:var(--s2);border-bottom:1px solid var(--acc);padding:10px 12px;min-height:52px;display:flex;align-items:center;gap:8px;position:relative}
.split-top-label{font-family:var(--mo);font-size:8px;letter-spacing:.16em;text-transform:uppercase;color:var(--acc);opacity:.7;position:absolute;top:6px;right:10px}
.split-top-icon{font-size:18px;flex-shrink:0;opacity:.8}
.split-top-txt{font-size:11px;color:var(--mt2);line-height:1.5;flex:1}
.split-top-txt strong{color:var(--tx);font-size:11px}

/* DIVIDER LINE */
.split-line{height:2px;background:linear-gradient(90deg,transparent,var(--acc),transparent);opacity:.5}

/* BOTTOM HALF — hook текст */
.split-bot{background:var(--s3);padding:12px 12px 10px;min-height:60px;display:flex;align-items:center;gap:8px;position:relative}
.split-bot-label{font-family:var(--mo);font-size:8px;letter-spacing:.16em;text-transform:uppercase;color:var(--mt);opacity:.6;position:absolute;top:6px;right:10px}
.split-mic{font-size:15px;flex-shrink:0;opacity:.7}
.split-hook{font-size:14px;font-weight:800;color:var(--wh);line-height:1.35;letter-spacing:-.01em;flex:1}

/* CARD FOOTER */
.scard-ft{padding:8px 12px;border-top:1px solid var(--bd);display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.tip-txt{font-size:10px;color:var(--mt);flex:1;line-height:1.5;min-width:0}
.cpybtn{font-family:var(--mo);font-size:10px;padding:8px 14px;border:1px solid var(--bd2);background:transparent;color:var(--mt2);cursor:pointer;letter-spacing:.06em;text-transform:uppercase;transition:all .15s;white-space:nowrap;flex-shrink:0;-webkit-tap-highlight-color:transparent;min-width:60px;text-align:center}
.cpybtn:active{background:var(--s2)}.cpybtn.ok{color:var(--good);border-color:var(--good)}

/* RANDOM CARD */
.rand-wrap{background:var(--s1);border:1px solid var(--acc);padding:0;margin-bottom:20px;position:relative;overflow:hidden}
.rand-wrap::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--acc),var(--acc2))}
.rand-lbl{font-family:var(--mo);font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--acc);padding:14px 16px 0}
.rand-split{display:flex;flex-direction:column;margin:10px 16px 0}
.rand-top{background:var(--s2);border:1px solid var(--bd2);border-bottom:2px solid var(--acc);padding:8px 12px;font-size:11px;color:var(--mt2);line-height:1.5}
.rand-top strong{color:var(--tx)}
.rand-bot{background:var(--s3);border:1px solid var(--bd2);border-top:none;padding:10px 12px}
.rand-hook-txt{font-size:17px;font-weight:800;color:var(--wh);line-height:1.3;letter-spacing:-.02em}
.rand-meta{font-size:11px;color:var(--mt2);padding:8px 16px 0}
.rand-acts{display:flex;gap:8px;padding:12px 16px 16px;flex-wrap:wrap}
.rbtn{padding:9px 18px;font-family:var(--mo);font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;border:none;transition:all .15s;-webkit-tap-highlight-color:transparent}
.rbtn.primary{background:var(--acc);color:#000}
.rbtn.sec{background:transparent;border:1px solid var(--bd2);color:var(--mt2)}

/* EMPTY */
.empty{text-align:center;padding:64px 20px;color:var(--mt);grid-column:1/-1}
.empty-ic{font-size:36px;margin-bottom:10px}
.empty-tx{font-size:13px;color:var(--mt2)}

/* TOAST */
.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--s2);border:1px solid var(--good);padding:10px 20px;font-family:var(--mo);font-size:12px;color:var(--good);z-index:1000;opacity:0;transition:all .25s;pointer-events:none;white-space:nowrap;box-shadow:0 8px 24px rgba(0,0,0,.5)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

@media(max-width:600px){
  .hero{padding:32px 16px 24px}
  .content{padding:16px 12px 80px}
  .how-banner{padding:0 12px}
  .nav-inner{padding:0 12px}
  .grid{grid-template-columns:1fr}
  .ntab{padding:12px 10px;font-size:10px}
  .nc{display:none}
  .how-item{min-width:140px}
}
</style>
</head>
<body>

<div class="hero">
